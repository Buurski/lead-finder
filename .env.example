# =============================================================================
# Command Center v3 — environment template
# Lines marked [REQUIRED] must be set or the relevant feature breaks loudly.
# Lines marked [OPTIONAL] enable a feature or override a sensible default.
# Lines marked [VERCEL] are auto-injected by the hosting platform on Vercel; do
# NOT set locally unless you specifically want to override.
# Lines marked [SENSITIVE] are credentials — never commit, never log, rotate
# after sharing.
# =============================================================================

# ---- CORE: Google Sheets (the lead store) ----------------------------------
# [REQUIRED] Spreadsheet ID — between /d/ and /edit in the sheet URL.
GOOGLE_SHEET_ID=your_spreadsheet_id_here
# [REQUIRED in prod, SENSITIVE] Full service-account JSON, single-line.
# Pick ONE of GOOGLE_SERVICE_ACCOUNT_JSON or GOOGLE_KEY_FILE.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
# [OPTIONAL, local-dev only] Filesystem path to the service-account JSON file.
GOOGLE_KEY_FILE=

# ---- CORE: AI gateway (Claude via gateway or direct) -----------------------
# [REQUIRED unless AI_DISABLED=1, SENSITIVE] Direct Anthropic key.
ANTHROPIC_API_KEY=
# [OPTIONAL, SENSITIVE] Vercel AI Gateway key — takes precedence over Anthropic.
AI_GATEWAY_API_KEY=
# [OPTIONAL] Override gateway base URL. Default = Vercel-managed.
AI_GATEWAY_BASE_URL=
# [OPTIONAL] Hard-disable AI calls (offline/dry-run smoke tests).
AI_DISABLED=
# [OPTIONAL] Model overrides; defaults defined in src/lib/ai.ts.
AI_MODEL_DRAFT=anthropic/claude-opus-4-8
AI_MODEL_QUALIFY=anthropic/claude-sonnet-4-6
AI_MODEL_RESEARCH=anthropic/claude-sonnet-4-6

# ---- STORAGE: Vercel KV (docs, append-logs, auth rate-limit) ---------------
# Choose a backend strategy via STORE_DRIVER:
#   fs    — local filesystem (.send_queue/ etc). Default outside Vercel.
#   cloud — Vercel KV + Vercel Blob. Default on Vercel.
STORE_DRIVER=
# [REQUIRED for cloud driver + auth rate-limit, VERCEL] Auto-injected when KV
# is attached to the project. For local-against-cloud, copy from Vercel UI.
KV_REST_API_URL=
# [REQUIRED, VERCEL, SENSITIVE] Read+write token.
KV_REST_API_TOKEN=
# [OPTIONAL, VERCEL] Read-only token (currently unused).
KV_REST_API_READ_ONLY_TOKEN=

# ---- STORAGE: Vercel Blob (served assets — demos, recon snapshots) ---------
# [REQUIRED for cloud driver, VERCEL, SENSITIVE] Auto-injected when Blob is attached.
BLOB_READ_WRITE_TOKEN=
# [OPTIONAL] Pretty domain for served demos (rewrites to Blob URL).
DEMO_PUBLIC_HOST=

# ---- VAULT: GitHub raw access to KnowledgeOS -------------------------------
# [OPTIONAL, SENSITIVE] Fine-grained PAT, repo:read on Buurski/KnowledgeOS only.
GITHUB_TOKEN=
# [OPTIONAL, SENSITIVE] Alternate name accepted by src/lib/vault.ts; preference
# is GITHUB_TOKEN. Set EITHER one, not both.
VAULT_GITHUB_TOKEN=
# [OPTIONAL] Repo override. Default Buurski/KnowledgeOS.
VAULT_REPO=Buurski/KnowledgeOS
# [OPTIONAL] Branch to read from. Default "master".
VAULT_BRANCH=master

# ---- OUTREACH: Gmail SMTP (cold-email + reply-sync) ------------------------
# [REQUIRED for outreach] Sender Gmail address. Lucas: buur.aigro@gmail.com.
GMAIL_USER=
# [REQUIRED for outreach, SENSITIVE] Gmail App Password (NOT account password).
# Generate at https://myaccount.google.com/apppasswords.
GMAIL_APP_PASSWORD=

# ---- OUTREACH: Charlie's Gmail (hybrid allokering 2026-06-17) --------------
# Hybrid afsender-pool: engine fordeler udkast mellem Lucas og Charlie
# ud fra hvem der har sendt færrest de seneste 14 dage (se senders.ts).
# Hvis kun én konto er sat, bruger ALLE udkast den (single-sender-mode).
# [OPTIONAL, SENSITIVE] Charlie's Gmail. Default: 1charlie.nielsen@gmail.com.
# BEMÆRK: Charlie skal også have et separat App Password (egen Gmail-konto).
CHARLIE_GMAIL_USER=1charlie.nielsen@gmail.com
# [OPTIONAL, SENSITIVE] Charlie's App Password. Hvis ikke sat, charlie
# er "utilgængelig" og allokeringen falder tilbage til Lucas.
CHARLIE_GMAIL_APP_PASSWORD=

# ---- AUTH: Basic auth gate (Lucas + Charlie shared password) ---------------
# All three must be set together to enable. Omitting any leaves every route
# public (acceptable for local dev only).
# [OPTIONAL] Username for the gate (same for both Lucas + Charlie).
VERCEL_BASIC_AUTH_USER=
# [OPTIONAL, SENSITIVE] Shared password — 20+ chars; ":" is now allowed.
VERCEL_BASIC_AUTH_PASS=
# [OPTIONAL, SENSITIVE] 32-byte random hex for HMAC session cookie. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET=

# ---- EXTERNAL: Apify (lead enrichment, deep-research) ----------------------
# [OPTIONAL] Master switch — set to "1" to enable Apify-backed enrichment.
# Off by default; lead-finder then uses Google Places + web fallback only.
ENABLE_APIFY=
# [OPTIONAL when ENABLE_APIFY!=1, SENSITIVE] Apify Personal API token.
APIFY_TOKEN=

# ---- EXTERNAL: Google Places (geo + business metadata) ---------------------
# [REQUIRED for lead-finder, SENSITIVE] Restrict the key by HTTP-referrer +
# Places API in the Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# ---- EXTERNAL: Recon (customer-site fingerprinting) ------------------------
# [OPTIONAL] Set to "1" to allow falling back to r.jina.ai readability proxy
# when raw HTML is JS-only. WARNING: this routes the customer URL through a
# third party (Singapore). GDPR review before enabling in production.
RECON_ALLOW_JINA=

# ---- CRON: scheduled jobs --------------------------------------------------
# [REQUIRED for Vercel Cron, SENSITIVE] Shared secret Vercel Cron passes as
# Authorization: Bearer <secret>. Validates /api/cron/* routes.
CRON_SECRET=

# ---- DEEP RESEARCH (Cowork-mode lead research) -----------------------------
# Pattern: Command Center generates a structured prompt; Lucas pastes it into
# a Cowork session (gratis sunk-cost); Cowork processes leads and POSTs
# results back to /api/leads/deep-research-result with this secret.
# [REQUIRED for prod, SENSITIVE] Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, the result endpoint accepts anything (local dev only — loud warn).
DEEP_RESEARCH_SECRET=

# ---- HERMES: 24/7 Telegram agent (Block 10 / Phase 2 hosting on Railway) ---
# [REQUIRED for hermes, SENSITIVE] From @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
# [REQUIRED for hermes] Lucas's Telegram chat ID — the ONLY allowed controller.
# Find via @userinfobot.
TELEGRAM_ALLOWED_CHAT_ID=
# [REQUIRED for hermes -> app callbacks] URL of the deployed Command Center.
# E.g. https://lead-finder-three-beta.vercel.app or http://localhost:3000 locally.
APP_URL=http://localhost:3000
# [OPTIONAL] Public URL where the Hermes service is running (Railway, Fly, etc.).
# Shown on src/app/hermes/page.tsx for the operator.
HERMES_URL=
# [OPTIONAL, SENSITIVE] ElevenLabs API key for the morning-podcast feature.
ELEVENLABS_API_KEY=
# [OPTIONAL, SENSITIVE] Whisper / OpenAI key for voice-note transcription.
OPENAI_API_KEY=

# =============================================================================
# Variables you do NOT need to set yourself
# - NODE_ENV, VERCEL_ENV, VERCEL_URL, VERCEL_GIT_*: injected by Vercel.
# - PORT: injected by managed hosts.
# =============================================================================
